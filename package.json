{
  "name": "third-login-service",
  "version": "1.0.0",
  "description": "统一第三方登录认证服务 - Cloudflare Worker",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --config wrangler.dev.toml",
    "deploy": "wrangler deploy --config wrangler.dev.toml",
    "deploy:dev": "wrangler deploy --config wrangler.dev.toml",
    "deploy:prod": "wrangler deploy --config wrangler.prod.toml",
    "db:migrate:dev": "wrangler d1 execute third-login-service-db-dev --file=./migrations/0001_init.sql",
    "db:migrate:prod": "wrangler d1 execute third-login-service-db-prod --file=./migrations/0001_init.sql"
  },
  "dependencies": {
    "hono": "^4.7.9",
    "jose": "^6.1.3",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251014.0",
    "@types/jsonwebtoken": "^9.0.7",
    "typescript": "^5.4.2",
    "wrangler": "^4.45.3"
  },
  "packageManager": "pnpm@10.11.0+sha512.6540583f41cc5f628eb3d9773ecee802f4f9ef9923cc45b69890fb47991d4b092964694ec3a4f738a420c918a333062c8b925d312f42e4f0c263eb603551f977"
}
